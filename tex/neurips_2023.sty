% NeurIPS 2023 Style File
% Created by the NeurIPS 2023 Program Chairs.
% Derived from earlier conference style files.

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2023}[2023/04/18 NeurIPS 2023 style file]

\RequirePackage{times}
\RequirePackage{fullpage}
\RequirePackage{setspace}

\newif\ifneurips@final
\DeclareOption{final}{\neurips@finaltrue}
\newif\ifneurips@nonatbib
\DeclareOption{nonatbib}{\neurips@nonatbibtrue}
\ProcessOptions\relax

\usepackage[utf8]{inputenc}
\usepackage[T1]{fontenc}
\usepackage{geometry}
\geometry{
  body={6.5in, 9.0in},
  left=1.0in,
  top=1.0in
}

\def\@maketitle{%
  \newpage
  \null
  \vskip 2em%
  \begin{center}%
  \let \footnote \thanks
    {\LARGE \bf \@title \par}%
    \vskip 1.5em%
    {\large
      \lineskip .5em%
      \begin{tabular}[t]{c}%
        \@author
      \end{tabular}\par}%
    \vskip 1em%
    {\large \@date}%
  \end{center}%
  \par
  \vskip 1.5em}

\setlength{\parindent}{0pt}
\setlength{\parskip}{1ex plus 0.5ex minus 0.2ex}

\renewenvironment{abstract}%
{%
  \centerline{\large\bf Abstract}%
  \vspace{0.5ex}%
  \begin{quote}%
}
{%
  \end{quote}%
}

\RequirePackage{titlesec}
\titleformat{\section}{\large\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{1em}{}

\ifneurips@nonatbib
\else
  \RequirePackage{natbib}
\fi

% 行号显示 (非 final 模式)
\ifneurips@final
\else
  \RequirePackage{lineno}
  \linenumbers
\fi

\endinput